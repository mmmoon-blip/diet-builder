.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.header {
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
  color: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

.new-chat-btn {
  font-size: 28rpx;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.chat-container {
  flex: 1;
  padding: 20rpx 30rpx;
  overflow-y: auto;
}

.message-item {
  display: flex;
  margin-bottom: 30rpx;
}

.message-item.user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.message-content {
  max-width: 70%;
  margin: 0 20rpx;
}

.message-text {
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

.message-item.bot .message-text {
  background: #fff;
  color: #333;
}

.message-item.user .message-text {
  background: #FF6B6B;
  color: #fff;
}

.message-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  text-align: right;
}

.message-item.user .message-time {
  text-align: left;
}

.empty-hint {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 100rpx 40rpx;
  line-height: 1.8;
  white-space: pre-line;
}

.input-container {
  background: #fff;
  padding: 20rpx 24rpx 60rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
}

.input-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #f8f8f8;
  border-radius: 48rpx;
  padding: 8rpx 8rpx 8rpx 20rpx;
  border: 1rpx solid #eee;
}

.input-tools {
  display: flex;
  gap: 4rpx;
}

.tool-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.5;
}

.tool-btn.active {
  background: #FFE5E5;
  opacity: 1;
}

.tool-btn text {
  font-size: 26rpx;
}

.input-field {
  flex: 1;
  height: 80rpx;
  font-size: 30rpx;
  background: transparent;
}

.send-btn {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
}

.send-btn::after {
  border: none;
}

.send-btn[disabled] {
  background: #ddd;
}

.image-preview {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 28rpx;
  background: #fff;
  margin-top: 16rpx;
  border-radius: 28rpx;
}

.image-preview image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 20rpx;
}

.image-info {
  flex: 1;
}

.remove-image {
  font-size: 28rpx;
  color: #FF6B6B;
}

.message-image {
  max-width: 300rpx;
  max-height: 300rpx;
  border-radius: 12rpx;
  margin-top: 10rpx;
}
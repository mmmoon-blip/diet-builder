.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.header {
  margin-bottom: 30rpx;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-value {
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  color: #333;
}

.time-picker {
  flex: 1;
  justify-content: center;
}

.form-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 20rpx;
}

.save-btn::after {
  border: none;
}

.summary-card {
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  color: #fff;
}

.summary-title {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 16rpx;
}

.summary-row {
  display: flex;
  justify-content: center;
}

.summary-item {
  text-align: center;
}

.summary-value {
  font-size: 64rpx;
  font-weight: bold;
}

.summary-unit {
  font-size: 28rpx;
  opacity: 0.8;
  margin-left: 8rpx;
}

.history-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.history-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-left {
  width: 120rpx;
}

.history-date {
  font-size: 22rpx;
  color: #999;
}

.history-meal {
  font-size: 24rpx;
  color: #FF6B6B;
  font-weight: 500;
}

.history-content {
  flex: 1;
  padding: 0 16rpx;
}

.history-foods {
  font-size: 28rpx;
  color: #333;
  display: block;
  line-height: 1.4;
}

.history-calories {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.history-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 28rpx;
  padding: 8rpx;
}

.action-btn.delete {
  color: #ff6b6b;
}

.empty-hint {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 40rpx 0;
}

.history-scroll {
  max-height: 500rpx;
}

.load-more {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 24rpx;
}

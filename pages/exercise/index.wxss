.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.header {
  margin-bottom: 30rpx;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.form-group {
  margin-bottom: 24rpx;
  position: relative;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.search-input {
  margin-bottom: 16rpx;
}

.exercise-filtered-list {
  max-height: 300rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
  overflow-y: auto;
  margin-bottom: 16rpx;
}

.exercise-filter-item {
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  border-bottom: 1rpx solid #f5f5f5;
}

.exercise-filter-item:last-child {
  border-bottom: none;
}

.exercise-filter-item:active {
  background: #f0f0f0;
}

.exercise-type-selector {
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.exercise-type-selector .picker-value {
  background: transparent;
  height: auto;
  padding: 0;
}

.dropdown-arrow {
  font-size: 24rpx;
  color: #999;
}

.exercise-dropdown {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  z-index: 100;
  max-height: 500rpx;
  display: flex;
  flex-direction: column;
}

.exercise-dropdown .search-input {
  margin: 16rpx;
  border: 1rpx solid #eee;
}

.dropdown-list {
  max-height: 400rpx;
  flex: 1;
}

.dropdown-item {
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  border-bottom: 1rpx solid #f5f5f5;
}

.dropdown-item:last-child {
  border-bottom: none;
}

.dropdown-item.selected {
  background: #FFF5F5;
  color: #FF6B6B;
  font-weight: bold;
}

.dropdown-item:active {
  background: #f0f0f0;
}

.dropdown-empty {
  padding: 40rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.picker-value {
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  color: #333;
}

.time-picker {
  flex: 1;
  justify-content: center;
}

.form-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 20rpx;
}

.save-btn::after {
  border: none;
}

.summary-card {
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  color: #fff;
}

.summary-title {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 16rpx;
}

.summary-row {
  display: flex;
  justify-content: space-around;
}

.summary-item {
  text-align: center;
}

.summary-value {
  font-size: 48rpx;
  font-weight: bold;
}

.summary-unit {
  font-size: 24rpx;
  opacity: 0.8;
  margin-left: 8rpx;
}

.history-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-date {
  font-size: 24rpx;
  color: #999;
  width: 160rpx;
}

.history-content {
  flex: 1;
}

.history-type {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.history-detail {
  font-size: 24rpx;
  color: #999;
}

.history-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 28rpx;
  padding: 8rpx;
}

.action-btn.delete {
  color: #ff6b6b;
}

.empty-hint {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 40rpx 0;
}

.history-scroll {
  max-height: 500rpx;
}

.load-more {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 24rpx;
}

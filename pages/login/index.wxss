.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-section {
  width: 100%;
  max-width: 600rpx;
}

/* 微信登录按钮 */
.btn-wechat {
  width: 100%;
  height: 96rpx;
  background: #07C160;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
  border: none;
}

.btn-wechat::after {
  border: none;
}

.btn-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.btn-hover {
  opacity: 0.9;
}

/* 分隔符 */
.divider {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.5);
}

.divider-text {
  padding: 0 30rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
}

/* 游客模式按钮 */
.btn-guest {
  width: 100%;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.btn-guest::after {
  border: none;
}

.tips {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 60rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.link {
  color: #fff;
  text-decoration: underline;
  margin: 0 4rpx;
}

.footer {
  position: fixed;
  bottom: 60rpx;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.footer-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.6;
}
